<Block_PillCloud>
    <NavLink class="pill palette-gamejam" href="@href" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-game-controller-duotone" Alt="Play" />@ChildContent<SvgSprite Link="/icons.svg?v=1#icon-external-link" class="external-link-icon" /></NavLink>
</Block_PillCloud>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string href { get; set; } = string.Empty;
}
