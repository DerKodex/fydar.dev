@inject Noncer noncer

@{
    var instanceId = $"unity_{Guid.NewGuid().ToString("N")}";
    var canvasId = $"{instanceId}_canvas";
}

<div id="@instanceId" class="embed loading" style="--loading-percentage: 0%;" @attributes="AdditionalAttributes">
    <canvas class="embed--canvas" id="@canvasId" width=960 height=600 tabindex="-1"></canvas>
    <div class="embed--placeholder">
        <div class="embed--placeholdermain">
            @Placeholder
            <div class="progress">
                <div class="progress--bar" style="width: var(--loading-percentage);"></div>
            </div>
        </div>
        <div class="embed--placeholderdetails">
            @if (Details != null)
            {
                @Details
            }
            else
            {
                <h1>@Config.ProductName</h1>

                <dl>
                    <dt>Version</dt>
                    <dd>@Config.ProductVersion</dd>

                    <dt>by</dt>
                    <dd>@Config.CompanyName</dd>
                </dl>
            }
        </div>
    </div>
    <div class="embed--warning"></div>

    <script nonce="@noncer.Nonce">
        var loaderUrl = "@Config.LoaderUrl";

        var script = document.createElement("script");
        script.src = loaderUrl;
        script.setAttribute("async", "");
        script.onload = () => {
            setTimeout(function () {
                var config = {
                    companyName: "@Config.CompanyName",
                    productName: "@Config.ProductName",
                    productVersion: "@Config.ProductVersion",
                    frameworkUrl: "@Config.FrameworkUrl",
                    codeUrl: "@Config.CodeUrl",
                    dataUrl: "@Config.DataUrl",
                    @if (!string.IsNullOrEmpty(Config.SymbolsUrl))
                    {
                                <text>symbolsUrl: "@Config.SymbolsUrl",</text>
                    }
                    @if (!string.IsNullOrEmpty(Config.MemoryUrl))
                    {
                                <text>memoryUrl: "@Config.MemoryUrl",</text>
                    }
                    streamingAssetsUrl: "@Config.StreamingAssetsUrl",
                    arguments: [@((MarkupString)(Config.Arguments.Length > 0 ? $"\"{string.Join("\", \"", Config.Arguments)}\"" : ""))]
                };

                var rootId = "@instanceId";
                var container = document.getElementById(rootId);
                var canvas = container.querySelector(".embed--canvas");
                var warningBanner = container.querySelector(".embed--warning");

                function unityShowBanner(msg, type) {
                    function updateBannerVisibility() {
                        warningBanner.style.display = warningBanner.children.length ? 'block' : 'none';
                    }
                    var div = document.createElement('div');
                    div.innerHTML = msg;
                    warningBanner.appendChild(div);
                    if (type == 'error') {
                        div.style = 'background: red; padding: 10px;';
                    } else {
                        if (type == 'warning') div.style = 'background: yellow; padding: 10px;';
                        setTimeout(function () {
                            warningBanner.removeChild(div);
                            updateBannerVisibility();
                        }, 5000);
                    }
                    updateBannerVisibility();
                }

                config.showBanner = unityShowBanner;

                createUnityInstance(canvas, config, (progress) => {
                    container.style.setProperty('--loading-percentage', 100 * progress + "%");
                }).then((unityInstance) => {
                    container.style.setProperty('--loading-percentage', "100%");

                    requestAnimationFrame(() => {
                        requestAnimationFrame(() => {
                            setTimeout(() => {
                                container.classList.remove("loading");
                            }, 100);
                        });
                    });
                }).catch((message) => {
                    alert(message);
                });
            }, 1);
        };
        document.body.appendChild(script);
    </script>

    <style>
        .embed {
            position: relative;
        }

            .embed div.embed--placeholder {
                position: absolute;
                width: 100%;
                height: 100%;
                overflow: hidden;
                opacity: 0;
                pointer-events: none;
                transition: opacity 0.25s;
                background: #161618;
            }

                .embed div.embed--placeholder div.embed--placeholdermain,
                .embed div.embed--placeholder div.embed--placeholderdetails {
                    position: absolute;
                    width: 100%;
                    height: 100%;
                }

                .embed div.embed--placeholder div.embed--placeholdermain {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    place-content: center;
                }

                .embed div.embed--placeholder div.embed--placeholderdetails {
                    place-content: end;
                    text-align: right;
                    box-sizing: border-box;
                    padding: 24px;
                    font-family: sans-serif;
                }

                    .embed div.embed--placeholder div.embed--placeholderdetails h1 {
                        font-size: 24px;
                        color: #aaaaaa;
                        margin-block-end: 0;
                        letter-spacing: 0.5px;
                        font-weight: 400;
                    }

                    .embed div.embed--placeholder div.embed--placeholderdetails dl {
                        font-size: 20px;
                        color: #7a8288;
                        margin-block-start: 6px;
                        margin-block-end: 0;
                        text-align: right;
                        line-height: 1.5;
                        letter-spacing: 0.25px;
                    }

                        .embed div.embed--placeholder div.embed--placeholderdetails dl dt {
                            display: inline;
                        }

                        .embed div.embed--placeholder div.embed--placeholderdetails dl dd {
                            display: inline;
                            margin-inline-start: unset;
                        }

                            .embed div.embed--placeholder div.embed--placeholderdetails dl dd:after {
                                content: '\A';
                                white-space: pre;
                            }

                .embed div.embed--placeholder .progress {
                    width: 300px;
                    max-width: 90%;
                    height: 18px;
                    border-radius: 6px;
                    overflow: hidden;
                    background-color: #ffffff1c;
                }

                    .embed div.embed--placeholder .progress .progress--bar {
                        width: 0%;
                        height: 100%;
                        background-image: linear-gradient(45deg, rgba(22, 23, 24, 0.15) 25%, rgba(0, 0, 0, 0) 25%, rgba(0, 0, 0, 0) 50%, rgba(22, 23, 24, 0.15) 50%, rgba(22, 23, 24, 0.15) 75%, rgba(0, 0, 0, 0) 75%, rgba(0, 0, 0, 0));
                        background-size: 18px 18px;
                        background-color: #0248b0;
                        transition: width 0.25s linear;
                        animation: 1s linear infinite progress--bar-stripes;
                    }


            .embed.loading div.embed--placeholder {
                opacity: 1;
            }

            .embed canvas.embed--canvas {
                position: absolute;
                width: 100%;
                height: 100%;
                outline: 0;
            }

            .embed div.embed--warning {
            }

        @@keyframes progress--bar-stripes {
            from {
                background-position: 18px 0;
            }

            to {
                background-position: 0 0;
            }
        }
    </style>
</div>

@code {
    [Parameter]
    public EmbedUnityConfig Config { get; set; }

    [Parameter]
    public RenderFragment? Placeholder { get; set; }

    [Parameter]
    public RenderFragment? Details { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object>? AdditionalAttributes { get; set; }
}
