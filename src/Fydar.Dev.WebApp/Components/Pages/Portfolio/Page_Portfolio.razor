					<Block_CoverGrid>
						<CoverDate Date="2025"><Cover_Phasmophobia /></CoverDate>
						<CoverDate Date="2024"><Cover_UNO /></CoverDate>
						<CoverDate><Cover_Southfield /></CoverDate>
						<CoverDate Date="2022"><Cover_Outrage /></CoverDate>
						<CoverDate><Cover_StarCitizen /></CoverDate>
						<CoverDate><Cover_Squadron42 /></CoverDate>
						<CoverDate Date="2020"><Cover_LegoStarWarsBattles /></CoverDate>
						<CoverDate Date="2018"><Cover_Eitr /></CoverDate>
					</Block_CoverGrid>
				</OutlineSection>

				<OutlineSection LinkName="Systems Engineer" Id="systems-engineer">
