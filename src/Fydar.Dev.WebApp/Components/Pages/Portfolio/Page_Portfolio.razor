@using Microsoft.AspNetCore.OutputCaching;

@layout DefaultLayout
@page "/"
@page "/portfolio"

@attribute [OutputCache(Duration = 600)]

@inject NavigationManager NavigationManager

@{
	var openGraphModel = new OpenGraphModel()
	{
		Title = "Portfolio - Fydar",
		Description = "Fydar is a game developer and engineer who thrives when pushing technical boundaries and creating memorable experiences.",
		CanonicalUrl = "https://fydar.dev",
		Properties = [
			new OpenGraphModelImage()
			{
				Url = "https://fydar.dev/media/header.webp",
				Alt = "A portrait of Fydar in an anime art style."
			}
		]
	};
	var linkData = new LinkData()
	{
		new LinkDataBreadcrumbList()
		{
			new LinkDataBreadcrumbListItem()
			{
				Name = "Portfolio",
				Item = "https://fydar.dev/"
			}
		}
	};
}

<HeadContent>
	<OpenGraphComponent Model="@openGraphModel" />
	<LinkDataComponent Model="@linkData" />

	<link rel="preload" href="@Assets["media/signature.svg"]" as="image" fetchpriority="high" />
</HeadContent>

<article class="page-portfolio">
	<div class="container">
		<Block_ArticleOutlined>
            <Sidebar>
                <aside>
                    <Block_PronunciationGuide_Fydar />

                    <h1>Fydar</h1>
                    <div class="subheading">The <b>Portfolio</b> <br /> of a <b>Programmer</b></div>

                    <menu class="externallinks" aria-label="Quick links" data-nosnippet>
                        <li><a href="https://github.com/Fydar" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-github" Alt="GitHub" /></a></li>
                        <li><a class="palette-linkedin" href="https://www.linkedin.com/in/fydar" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-linkedin" Alt="LinkedIn" /></a></li>
                        <li class="palette-youtube"><a href="https://www.youtube.com/@@fydar" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-youtube" Alt="YouTube" /></a></li>
                        <li><a href="https://assetstore.unity.com/publishers/13236" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-unity" Alt="Unity Asset Store" /></a></li>
                    </menu>
                    <Block_TableOfContents />
                </aside>
			</Sidebar>
			<Content>

				<img decoding="async" class="feature-signature" src="@Assets["media/signature.svg"]" alt="Fydar's signature." data-nosnippet />

