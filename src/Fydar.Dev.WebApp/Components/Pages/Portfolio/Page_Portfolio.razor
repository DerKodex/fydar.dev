							</div>
						</Card>
						<Card>
							<a class="card__link" href="/portfolio/inventory">Inventory</a>
							<SvgSprite class="card__image" Link="/icons.svg?v=1#icon-inventory" Alt="An illustration of the node based editor." />
							<div class="container">
								<header>
									<SvgSprite class="card-keyicon" Link="/icons.svg?v=1#icon-fydarinventory" />
