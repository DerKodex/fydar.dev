@layout DefaultLayout
@page "/portfolio/pewpew"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Pew Pew - Fydar",
        Description = "A 20v20 .io style browser game made in 48 hours using ASP.NET Core and hosted in AWS.",
        CanonicalUrl = "https://fydar.dev/portfolio/pewpew",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/pewpew/social.webp",
                Alt = "Promotional material for the game 'Pew Pew'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Pew Pew",
                Item = "https://fydar.dev/portfolio/pewpew"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<article class="page-pewpew">

    <div class="container">
        <Block_ArticleHeader>
            <h1 data-nosnippet>Pew Pew</h1>
        </Block_ArticleHeader>

        <Block_ArticleIntroduction>
            <Sidebar>
                <img decoding="async" class="article-featuredimage" src="@Assets["media/pewpew/social.webp"]" alt="Promotional material for the game 'Pew Pew'." />

                <Block_PillCloud>
                    <Pill_GameJam />
                    <Pill_Backend />
                    <Pill_CSharp />
                    <Pill_Multiplayer />
                </Block_PillCloud>

                <p>@openGraphModel.Description.Default</p>

                <menu class="externallinks" aria-label="Project External links">
                    <li><a href="https://github.com/fydar/PewPew" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-github" Alt="GitHub" /></a></li>
                    <li class="palette-youtube"><a href="https://youtu.be/9DOz6ob91zM" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-youtube" Alt="YouTube" /></a></li>
                </menu>

                <ShareLink Url="@openGraphModel.CanonicalUrl.Html" />
            </Sidebar>
            <Container>
                <EmbedYouTube Url="https://www.youtube-nocookie.com/embed/9DOz6ob91zM?si=9wSx2SPaN7-wz7OO" />
            </Container>
        </Block_ArticleIntroduction>

        <Block_ArticleOutlined>
            <Sidebar>
                <aside>
                    <Block_TableOfContents />
                </aside>
            </Sidebar>
            <Content>

                <OutlineSection Id="work-in-progress" LinkName="Work-in-progress">
                    <Block_ArticleHeading>
                        <h2>Work-in-progress</h2>
                    </Block_ArticleHeading>

                    <Block_Callout Type="construction">
                        <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                        <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                    </Block_Callout>
                </OutlineSection>

            </Content>
        </Block_ArticleOutlined>
    </div>
</article>
