@layout DefaultLayout
@page "/portfolio/thedwellers"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "The Dwellers - Fydar",
        Description = "A 3D dungeon crawler game demo with a full RPG item system, featuring a wide range of weapons and other equipment.",
        CanonicalUrl = "https://fydar.dev/portfolio/thedwellers",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/thedwellers/social.webp",
                Alt = "Promotional material for the game 'The Dwellers'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "The Dwellers",
                Item = "https://fydar.dev/portfolio/thedwellers"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<article class="page-systems">

    <div class="fullscreen" data-nosnippet>
        <div class="parallax-frame parallax-focalanchortop" style="--animation-time: 0.5;">
            <picture class="parallax-layer" style="--parallax-multiplier: 0.5">
                <img decoding="async" src="@Assets["media/thedwellers/background.webp"]" style="object-position: 42% 50%;" />
            </picture>
        </div>

        <div class="fullscreen-footer">
            <div class="container">
                <picture>
                    <img decoding="async" class="titlecard" src="@Assets["media/thedwellers/titlecard.svg"]" alt="Title card for the game 'The Dwellers'." />
                </picture>

                <div class="titlerow">
                    <div class="flexible-space"></div>
                    <SteamPlayButton href="/play/thedwellers">Play in Browser</SteamPlayButton>
                </div>
            </div>
        </div>

        <div class="cascade-container">
            <div class="cascade" style="background: linear-gradient(to right, #302e3200 0%, #302e3230 75%, #302e3214 100%), url('media/noise.svg');">
            </div>
        </div>
    </div>

    <div class="container">
        <Block_ArticleHeader>
            <h1 data-nosnippet>The Dwellers</h1>
        </Block_ArticleHeader>

        <Block_ArticleIntroduction>
            <Sidebar>
                <img decoding="async" class="article-featuredimage" src="@Assets["media/thedwellers/social.webp"]" alt="Promotional material for the game 'The Dwellers'." />

                <Block_PillCloud>
                    <Pill_Northbrook />
                    <Pill_GameJam />
                    <Pill_Tools />
                    <Pill_Unity />
                    <Pill_CSharp />
                </Block_PillCloud>

                <p>@openGraphModel.Description.Default</p>

                <menu class="externallinks" aria-label="Project External links">
                    <li class="palette-youtube"><a href="https://youtu.be/ksa6ccxi0Ug" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-youtube" Alt="YouTube" /></a></li>
                </menu>

                <ShareLink Url="@openGraphModel.CanonicalUrl.Html" />
            </Sidebar>
            <Container>
                <EmbedYouTube Url="https://www.youtube-nocookie.com/embed/ksa6ccxi0Ug?si=hheiAYNLLLx_EhRv" />
            </Container>
        </Block_ArticleIntroduction>

        <Block_ArticleOutlined>
            <Sidebar>
                <aside>
                    <Block_TableOfContents />
                </aside>
            </Sidebar>
            <Content>

                <OutlineSection Id="inventory-and-items" LinkName="Inventory and Items">
                    <Block_ArticleHeading>
                        <SvgSprite class="media" Link="/icons.svg?v=1#icon-knapsack" />
                        <hgroup>
                            <p>Implementing</p>
                            <h2>Inventory and Items</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <Block_Callout Type="construction">
                        <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                        <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                    </Block_Callout>
                </OutlineSection>

            </Content>
        </Block_ArticleOutlined>
    </div>
</article>
