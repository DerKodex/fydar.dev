@layout DefaultLayout
@page "/portfolio/legostarwarsbattles"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "LEGO® Star Wars™ Battles - Fydar",
        Description = "A mobile multiplayer realtime strategy game featuring competitive ranked matchmaking, weekly leaderboards, and clans.",
        CanonicalUrl = "https://fydar.dev/portfolio/legostarwarsbattles",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/legostarwarsbattles/social.webp",
                Alt = "Promotional material for the game 'LEGO® Star Wars™ Battles'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "LEGO® Star Wars™ Battles",
                Item = "https://fydar.dev/portfolio/legostarwarsbattles"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<article class="page-legostarwarsbattles">

    <div class="fullscreen" data-nosnippet>
        <div class="parallax-frame parallax-focalanchortop" style="--animation-time: 0.5;">
            <div class="parallax-layer" style="--parallax-multiplier: 0.5;">
                <div class="blur" style="background: radial-gradient(100% 100% at 50% 50%, #070b13 25%, #0f182e 100%);">
                </div>
            </div>

            <video class="parallax-layer" style="--parallax-multiplier: 0.5" autoplay muted loop>
                <source src="@Assets["media/legostarwarsbattles/background.1080p.30fps.h265.mp4"]" type='video/mp4; codecs="hvc1.1.2.L120.90"; profiles="isom,iso2,mp41"'>
                <source src="@Assets["media/legostarwarsbattles/background.1080p.30fps.h264.mp4"]" type='video/mp4; codecs="avc1.4d4028"; profiles="isom,iso2,avc1,mp41"'>
            </video>
        </div>

        <div class="fullscreen-footer">
            <div class="container">
                <picture>
                    <img decoding="async" class="titlecard" src="@Assets["media/legostarwarsbattles/titlecard.png"]" alt="Title card for the game 'LEGO® Star Wars™ Battles'." />
                </picture>

                <div class="titlerow">
                    <div class="flexible-space"></div>
                    <SteamPlayButton href="https://apps.apple.com/us/app/lego-star-wars-battles/id1563174698">Apple Arcade</SteamPlayButton>
                </div>
            </div>
        </div>

        <div class="cascade-container">
            <div class="cascade" style="background: linear-gradient(to right, #313d6c00 0%, #313d6c30 75%, #313d6c14 100%), url('media/noise.svg');">
            </div>
        </div>
    </div>

    <SvgSpritesheet>
        <Fydar.Dev.WebApp.Toolkit.Icons.CustomIcons.Sift />
    </SvgSpritesheet>

    <div class="container">
        <Block_ArticleHeader>
            <h1 data-nosnippet>LEGO® Star Wars™ Battles</h1>
        </Block_ArticleHeader>

        <Block_ArticleIntroduction>
            <Sidebar>
                <img decoding="async" class="article-featuredimage" src="@Assets["media/legostarwarsbattles/social.webp"]" alt="Promotional material for the game 'LEGO® Star Wars™ Battles'." />

                <Block_PillCloud>
                    <Pill_Backend />
                    <Pill_Tools />
                    <Pill_Unity />
                    <Pill_CSharp />
                    <Pill_Multiplayer />
                </Block_PillCloud>

                <p>@openGraphModel.Description.Default</p>

                <menu class="externallinks" aria-label="Project External links">
                    <li><a href="https://www.starwars.com/games-apps/lego-star-wars-battles" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-globe" Alt="Website" /></a></li>
                    <li class="palette-appstore"><a href="https://apps.apple.com/us/app/lego-star-wars-battles/id1563174698" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-applearcade" Alt="Apple Arcade" /></a></li>
                    <li class="palette-youtube"><a href="https://youtu.be/XGWJk2GxE7c" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-youtube" Alt="YouTube" /></a></li>
                </menu>

                <ShareLink Url="@openGraphModel.CanonicalUrl.Html" />
            </Sidebar>
            <Container>
                <EmbedYouTube Url="https://www.youtube-nocookie.com/embed/XGWJk2GxE7c?si=TnG83ijVHiEqB12P" />
            </Container>
        </Block_ArticleIntroduction>

        <Block_ArticleOutlined>
            <Sidebar>
                <aside>
                    <Block_TableOfContents />
                </aside>
            </Sidebar>
            <Content>
                <OutlineSection Id="leaderboards" LinkName="Leaderboards">
                    <Block_ArticleHeading>
                        <img class="media" decoding="async" src="@Assets["media/legostarwarsbattles/icon-leagues.webp"]" alt="The icon for Leaderboards." />
                        <hgroup>
                            <p>Servers and infrastructure for</p>
                            <h2>Leaderboards</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <p>I took the role of the <b>Feature Lead</b> to implement weekly leaderboard system. This involved me first provisioning cloud resources and implementing the server systems for leaderboards, and finally implementing a basic UI that can later be reskinned.</p>

                    <p>To finish off the Leaderboards feature, I also made an in-browser tool to inspect the state of the Leaderboards and manually modify them using <b>ASP.NET Core</b>.</p>

                    <figure class="figure-image">
                        <picture>
                            <img decoding="async" loading="lazy" src="@Assets["media/legostarwarsbattles/leagues.webp"]" alt="A screenshot from the game 'LEGO® Star Wars™ Battles' featuring a Leaderboard." />
                        </picture>
                        <figcaption>Screenshot from the <a href="https://www.gameuidatabase.com/gameData.php?id=1244" target="_blank">Game UI Database<SvgSprite Link="/icons.svg?v=1#icon-external-link" class="external-link-icon" /></a>.</figcaption>
                    </figure>

                    <Block_Callout>
                        <Icon><SvgSprite Link="/icons.svg?v=1#icon-seal-check-fill" Alt="Check" /></Icon>
                        <ChildContent>My leaderboards have stood the test of time and proven to be highly scalable to high volumes of players.</ChildContent>
                    </Block_Callout>

                </OutlineSection>

                <OutlineSection Id="clans" LinkName="Clans">
                    <Block_ArticleHeading>
                        <img class="media" decoding="async" src="@Assets["media/legostarwarsbattles/icon-clans.webp"]" alt="The icon for Clans." />
                        <hgroup>
                            <p>Servers and infrastructure for</p>
                            <h2>Clans</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <p>I took the role of the <b>Feature Lead</b> to implement the Clans social system. Much like with the <b>Leaderboards</b>, I started by developing the server-side systems and finished with the client-side UI.</p>

                    <Block_CutContent>
                        <ChildContent>
                            This feature was cut from the game.
                        </ChildContent>
                    </Block_CutContent>

                </OutlineSection>

                <OutlineSection Id="username-moderation" LinkName="Username Moderation">
                    <Block_ArticleHeading>
                        <SvgSprite class="media" Link="#icon-sift" />
                        <hgroup>
                            <p>Servers and infrastructure for</p>
                            <h2>Username Moderation</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <p>I created our username moderation pipeline utilising a third-party neural moderation API provided by <i>Community Sift</i>.</p>

                    <p>To manage the username moderation, I created the <b>Name Audit Tool</b>, a web-facing dashboard that allowed developers to quickly and easily assess the status of username moderation.</p>

                </OutlineSection>

                <OutlineSection Id="server-side-receipt-validation" LinkName="Server-Side Receipt Validation">
                    <Block_ArticleHeading>
                        <img class="media" decoding="async" src="@Assets["media/legostarwarsbattles/icon-stud-pile.webp"]" alt="The icon for the shop." />
                        <hgroup>
                            <p>Servers and infrastructure for</p>
                            <h2>Server-Side Receipt Validation</h2>
                        </hgroup>
                    </Block_ArticleHeading>


                    <p>In order to protect our game from fraudulent receipts being sent to our server in order to get free rewards, receipts from the Google Play Store and the Apple App Store have to be validated by our servers to ensure the receipt is from a valid transaction.</p>

                    <Block_CutContent>
                        <ChildContent>
                            <p>This feature was cut from the game.</p>
                            <p>When the game released on Apple Arcade, all monetization features were removed.</p>
                        </ChildContent>
                    </Block_CutContent>

                </OutlineSection>

                <OutlineSection Id="updates-and-data-delivery" LinkName="Updates and Data Delivery">
                    <Block_ArticleHeading>
                        <img class="media" decoding="async" src="@Assets["media/legostarwarsbattles/icon-asteroid.webp"]" alt="The icon for rewards." />
                        <hgroup>
                            <p>Servers and infrastructure for</p>
                            <h2>Updates and Data Delivery</h2>
                        </hgroup>
                    </Block_ArticleHeading>
                    <p>I architected and implemented the infrastructure necessary to deliver update data to our users.</p>

                    <p>Because of the nature of updating a live service mobile game, the mechanism had to take care to allow players using different versions of the game to share cloud resources such as databases and servers.</p>

                    <picture>
                        <img decoding="async" loading="lazy" src="@Assets["media/legostarwarsbattles/heroes-collage.png"]" alt="A collage of hero cards." style="width: 100%;" />
                    </picture>
                </OutlineSection>
            </Content>
        </Block_ArticleOutlined>

        <!--
            Save data management tools
            profile management tools
            network debugging tools
            configuration system
        -->
    </div>
</article>
