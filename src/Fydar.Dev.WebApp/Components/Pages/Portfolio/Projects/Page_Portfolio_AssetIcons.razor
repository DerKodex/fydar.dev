@layout DefaultLayout
@page "/portfolio/asseticons"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "AssetIcons - Fydar",
        Description = "Assign your own unique icon to each of your ScriptableObjects.",
        CanonicalUrl = "https://fydar.dev/portfolio/asseticons",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/asseticons/social.webp",
                Alt = "Promotional material for 'AssetIcons'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "AssetIcons",
                Item = "https://fydar.dev/portfolio/asseticons"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<section class="fullscreen" data-nosnippet>
    <div class="parallax-frame parallax-focalanchortop" style="--animation-time: 0.5;">
        <picture class="parallax-layer" style="--parallax-multiplier: 0.5">
            <img decoding="async"src="@Assets["media/asseticons/background.webp"]" />
        </picture>
    </div>

    <div class="fullscreen-footer">
        <div class="fullscreen-footer-container container container-wide">
            <div class="titlerow">
                <div class="flexible-space"></div>
                <SteamPlayButton href="https://assetstore.unity.com/packages/tools/utilities/asseticons-100547">Visit the Asset Store</SteamPlayButton>
            </div>
        </div>
    </div>
</section>

<div class="cascade-container">
    <div class="cascade" style="background: linear-gradient(to right, #f6973247 0%, #ef3d7a3d 75%, #ff00dd3b 100%), url(media/noise.svg);">
    </div>
</div>

<section class="container container-wide" data-nosnippet>
    <h1>AssetIcons</h1>
</section>

<aside class="project-summary">
    <section>
        <img decoding="async"class="project-featuredimage" src="@Assets["media/asseticons/social.webp"]" alt="Promotional material for the game 'AssetIcons'." />

        <PillCloud>
            <Pill_Tools />
            <Pill_Unity />
        </PillCloud>

        <p>@openGraphModel.Description.Default</p>

        <menu class="externallinks" aria-label="Project External links">
            <li><a href="https://assetstore.unity.com/packages/tools/utilities/asseticons-100547" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-unity" Alt="Unity Asset Store" /></a></li>
            <li><a href="https://github.com/fydar/AssetIcons" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-github" Alt="GitHub" /></a></li>
            <li class="palette-youtube"><a href="https://youtu.be/9tq5_naSYmM" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-youtube" Alt="YouTube" /></a></li>
        </menu>

        <ShareLink Url="@openGraphModel.CanonicalUrl.Html" />
    </section>
</aside>

<section class="container">
    <EmbedYouTube Url="https://www.youtube-nocookie.com/embed/9tq5_naSYmM?si=OiJLTkEf7XFaxuQ9" />
</section>

<HeadingScope>

    <aside>
        <section style="position: sticky; top: 64px;">
            <div style="height: 5rem"></div>
            <TableOfContents />
        </section>
    </aside>

    <section class="container">

        <Heading Level="2" Identifier="demo">
            <Text>Demo Included</Text>
            <Content>

                <figure class="figure-image">
                    <picture>
                        <img decoding="async"loading="lazy" src="@Assets["media/asseticons/asseticons-voxel-icons.png"]" alt="Demo collection of AssetIcons in the project window." />
                    </picture>
                    <figcaption>The project window with icons drawn by AssetIcons.</figcaption>
                </figure>

            </Content>
        </Heading>

        <Heading Level="2" Identifier="documentation">
            <Text>Well Documented</Text>
            <Content>

                <figure class="figure-image">
                    <picture>
                        <img decoding="async"loading="lazy" src="@Assets["media/asseticons/asseticons-documentation-1.png"]" alt="The AssetIcons documentation." />
                    </picture>
                    <figcaption>Screenshot of <a href="https://fydar.github.io/AssetIcons/Documentation#home" target="_blank">the AssetIcons documentation<SvgSprite Link="/icons.svg?v=1#icon-external-link" class="external-link-icon" /></a>.</figcaption>
                </figure>

            </Content>
        </Heading>

        <Heading Level="2" Identifier="features">
            <Text>Features</Text>
            <Content>

                <ul>
                    <li>Dynamic icons for ScriptableObjects</li>
                    <li>Custom icons per file extension</li>
                    <li>Customize icons with attribute-defined styles</li>
                    <li>Easy-to-use</li>
                    <li>High-quality documentation</li>
                    <li>Public issue tracker</li>
                    <li>In-editor update checker</li>
                    <li>Error detection and reporting</li>
                    <li>Support for Unity's Collaborate overlay</li>
                    <li>Support for Unity's Version Control overlay</li>
                </ul>

            </Content>
        </Heading>

        <Heading Level="2" Identifier="update-checker">
            <Text>Update Checker</Text>
            <Content>

                <p>AssetIcons includes a utility to quickly and easily check for updates.</p>

                <figure class="figure-image">
                    <picture>
                        <img decoding="async"loading="lazy" src="@Assets["media/asseticons/asseticons-update-checker.png"]" alt="The AssetIcons update checker." />
                    </picture>
                    <figcaption>The update checker window.</figcaption>
                </figure>

            </Content>
        </Heading>


    </section>
</HeadingScope>
