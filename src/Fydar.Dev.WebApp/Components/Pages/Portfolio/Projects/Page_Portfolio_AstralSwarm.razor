@layout DefaultLayout
@page "/portfolio/astralswarm"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Astral Swarm - Fydar",
        Description = "Battle endless swarms of enemy space ships across the galaxy.",
        CanonicalUrl = "https://fydar.dev/portfolio/astralswarm",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/astralswarm/social.webp",
                Alt = "Promotional material for the game 'Astral Swarm'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Astral Swarm",
                Item = "https://fydar.dev/portfolio/astralswarm"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<section class="fullscreen" data-nosnippet>
    <div class="parallax-frame parallax-focalanchortop" style="--animation-time: 0.5;">
        <picture class="parallax-layer" style="--parallax-multiplier: 0.5">
            <img src="@Assets["media/astralswarm/background.webp"]" />
        </picture>
    </div>

    <div class="fullscreen-footer">
        <div class="fullscreen-footer-container container container-wide">
            <picture>
                <img class="titlecard" src="@Assets["media/astralswarm/titlecard.webp"]" alt="Title card for the game 'Astral Swarm'." />
            </picture>

            <div class="titlerow">
                <div class="flexible-space"></div>
                <SteamPlayButton href="/play/astralswarm">Play in Browser</SteamPlayButton>
            </div>
        </div>
    </div>
</section>

<div class="cascade-container">
    <div class="cascade" style="background: linear-gradient(to right, #0043bf40 0%, #0043bf57 75%, #0043bf20 100%), url('media/noise.svg');">
    </div>
</div>

<section class="container container-wide" data-nosnippet>
    <h1>Astral Swarm</h1>
</section>

<aside class="project-summary">
    <section>
        <img class="project-featuredimage" src="@Assets["media/astralswarm/social.webp"]" alt="Promotional material for the game 'Astral Swarm'." />

        <PillCloud>
            <Pill_OutOfTheBlueStudios />
            <Pill_GameJam />
            <Pill_Unity />
            <Pill_CSharp />
        </PillCloud>

        <p>Battle endless swarms of enemy space ships across the galaxy.</p>

        <menu class="externallinks" aria-label="Project External links">
        </menu>

        <ShareLink Url="@openGraphModel.CanonicalUrl.Html" />
    </section>
</aside>

<HeadingScope>
    <aside>
        <section style="position: sticky; top: 64px;">
            <div style="height: 5rem"></div>
            <TableOfContents />
        </section>

    </aside>

    <section class="container">

        <Heading Level="2" Identifier="wip">
            <Prefix></Prefix>
            <Text>Work-in-progress</Text>
            <Content>

                <Callout Type="construction">
                    <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                    <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                </Callout>

            </Content>
        </Heading>

    </section>
</HeadingScope>
