@layout DefaultLayout
@page "/portfolio/eitr"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "EITR - Fydar",
        Description = "A soulslike RPG built around exceptional combat and formidable challenges set within a mythological Norse world.",
        CanonicalUrl = "https://fydar.dev/portfolio/eitr",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/eitr/social.webp",
                Alt = "Promotional material for the game 'EITR'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "EITR",
                Item = "https://fydar.dev/portfolio/eitr"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<article class="page-eitr">

    <div class="fullscreen" data-nosnippet>
        <div class="parallax-frame parallax-focalanchortop" style="--animation-time: 0.5;">
            <div class="parallax-layer" style="--parallax-multiplier: 0.5;">
                <div class="blur" style="background: radial-gradient(100% 100% at 50% 50%, #2C353C, #151F26, #0D1318);">
                </div>
            </div>

            <video class="parallax-layer" style="--parallax-multiplier: 0.5" autoplay muted loop>
                <source src="@Assets["media/eitr/background.720p.29fps.h265.mp4"]" type='video/mp4; codecs="hev1.1.2.L93.90"; profiles="isom,iso2,mp41"'>
                <source src="@Assets["media/eitr/background.720p.29fps.h264.mp4"]" type='video/mp4; codecs="avc1.4d401f"; profiles="isom,iso2,avc1,mp41"'>
            </video>
        </div>

        <div class="fullscreen-footer">
            <div class="container">
                <picture>
                    <img decoding="async" class="titlecard" src="@Assets["media/eitr/titlecard.png"]" alt="Title card for the game 'EITR'." style="image-rendering: pixelated;" />
                </picture>

                <div class="titlerow">
                    <div class="flexible-space"></div>
                    <SteamPlayButton href="https://store.steampowered.com/app/350050/EITR/">Visit on Steam</SteamPlayButton>
                </div>
            </div>
        </div>

        <div class="cascade-container">
            <div class="cascade" style="background: linear-gradient(to right, #ff810029 0%, #00ffd029 75%, #00ff7429 100%), url(media/noise.svg);">
            </div>
        </div>
    </div>

    <div class="container">
        <Block_ArticleHeader>
            <h1 data-nosnippet>EITR</h1>
        </Block_ArticleHeader>

        <Block_ArticleIntroduction>
            <Sidebar>
                <img decoding="async" class="article-featuredimage" src="@Assets["media/eitr/social.webp"]" alt="Promotional material for the game 'Eitr'." />

                <Block_PillCloud>
                    <Pill_Tools />
                    <Pill_Unity />
                    <Pill_CSharp />
                </Block_PillCloud>

                <p>@openGraphModel.Description.Default</p>

                <menu class="externallinks" aria-label="Project External links">
                    <li><a href="https://eitrthegame.com/" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-globe" Alt="Website" /></a></li>
                    <li class="palette-steam"><a href="https://store.steampowered.com/app/350050/EITR/" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-steam" Alt="Steam" /></a></li>
                    <li><a class="palette-twitter" href="https://twitter.com/EitrTheGame" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-twitter" Alt="Twitter" /></a></li>
                    <li><a class="palette-discord" href="https://discordapp.com/invite/ZQT7DtB" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-discord" Alt="Discord" /></a></li>
                    <li class="palette-youtube"><a href="https://youtu.be/z4EWdcoSpAo" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-youtube" Alt="YouTube" /></a></li>
                </menu>

                <ShareLink Url="@openGraphModel.CanonicalUrl.Html" />
            </Sidebar>
            <Container>
                <EmbedYouTube Url="https://www.youtube-nocookie.com/embed/z4EWdcoSpAo?si=HMri-k_GT7woe8eT" />
            </Container>
        </Block_ArticleIntroduction>

        <Block_ArticleOutlined>
            <Sidebar>
                <aside>
                    <Block_TableOfContents />
                </aside>
            </Sidebar>
            <Content>

                <OutlineSection Id="skill-tree-editing" LinkName="Skill Tree Editing">
                    <Block_ArticleHeading>
                        <SvgSprite class="media" Link="/icons.svg?v=1#icon-network-right-solid" />
                        <hgroup>
                            <p>Tooling for</p>
                            <h2>Skill Tree Editing</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <figure class="figure-image">
                        <picture>
                            <img decoding="async" loading="lazy" src="@Assets["media/eitr/skill-tree-editor-1-w900.jpg"]" alt="A screenshot of my skill tree editor editing a large skill tree." />
                        </picture>
                        <figcaption>A skill tree for ‘EITR’ inspired by those from <a href="https://www.pathofexile.com/" target="_blank">‘Path of Exile’<SvgSprite Link="/icons.svg?v=1#icon-external-link" class="external-link-icon" /></a>.</figcaption>
                    </figure>

                    <p>The skill tree went through multiple iterations thanks to the tooling provided.</p>

                    <figure class="figure-image">
                        <picture>
                            <img decoding="async" loading="lazy" src="@Assets["media/eitr/skill-tree-editor-2-w900.jpg"]" alt="A screenshot of my skill tree editor editing a smaller skill tree." />
                        </picture>
                        <figcaption>A skill tree for ‘EITR’ inspired by Nordic runes.</figcaption>
                    </figure>

                    <Block_Callout>
                        <Icon><SvgSprite Link="/icons.svg?v=1#icon-seal-check-fill" Alt="Check" /></Icon>
                        <ChildContent>The editor was able to provide all the tools necessary to explore different styles.</ChildContent>
                    </Block_Callout>

                </OutlineSection>

                <OutlineSection Id="inventories" LinkName="Inventories">
                    <Block_ArticleHeading>
                        <SvgSprite class="media" Link="/icons.svg?v=1#icon-fydarinventory" />
                        <hgroup>
                            <p>Systems Programming for</p>
                            <h2>Inventories</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <Block_Callout Type="construction">
                        <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                        <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                    </Block_Callout>

                </OutlineSection>

                <OutlineSection Id="items" LinkName="Items">
                    <Block_ArticleHeading>
                        <SvgSprite class="media" Link="/icons.svg?v=1#icon-fydarinventory" />
                        <hgroup>
                            <p>Systems Programming for</p>
                            <h2>Items</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <Block_Callout Type="construction">
                        <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                        <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                    </Block_Callout>

                </OutlineSection>

                <OutlineSection Id="achievements" LinkName="Achievements">
