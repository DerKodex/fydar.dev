                            <p>Systems Programming for</p>
                            <h2>Achievements</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <Block_Callout Type="construction">
                        <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                        <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                    </Block_Callout>

                </OutlineSection>

                <OutlineSection Id="input-mapping" LinkName="Input Mapping">
                    <Block_ArticleHeading>
                        <SvgSprite class="media" Link="/icons.svg?v=1#icon-fydarinventory" />
                        <hgroup>
                            <p>Systems Programming for</p>
                            <h2>Input Mapping</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <Block_Callout Type="construction">
                        <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                        <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                    </Block_Callout>

                </OutlineSection>

                <OutlineSection Id="stats" LinkName="Character Stats">
                    <Block_ArticleHeading>
                        <SvgSprite class="media" Link="/icons.svg?v=1#icon-fydarinventory" />
                        <hgroup>
                            <p>Systems Programming for</p>
                            <h2>Character Stats</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <Block_Callout Type="construction">
                        <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                        <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                    </Block_Callout>

                </OutlineSection>

                <OutlineSection Id="tooltips" LinkName="Tooltips">
                    <Block_ArticleHeading>
                        <SvgSprite class="media" Link="/icons.svg?v=1#icon-fydarinventory" />
                        <hgroup>
                            <p>Systems Programming for</p>
                            <h2>Tooltips</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <Block_Callout Type="construction">
                        <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                        <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                    </Block_Callout>

                </OutlineSection>

            </Content>
        </Block_ArticleOutlined>
    </div>
</article>
