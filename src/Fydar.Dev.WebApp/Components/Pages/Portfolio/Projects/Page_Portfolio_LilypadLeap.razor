@layout DefaultLayout
@page "/portfolio/lilypadleap"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Lilypad Leap - Fydar",
        Description = "A meditative and addictive game where you jump a frog across lily pads.",
        CanonicalUrl = "https://fydar.dev/portfolio/lilypadleap",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/lilypadleap/social.png",
                Alt = "Promotional material for the game 'Lilypad Leap'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Lilypad Leap",
                Item = "https://fydar.dev/portfolio/lilypadleap"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<article class="page-lilypadleap">

    <div class="fullscreen" data-nosnippet>
        <div class="parallax-frame parallax-focalanchortop" style="--animation-time: 0.5;">
            <picture class="parallax-layer" style="--parallax-multiplier: 0.5">
                <img decoding="async" src="@Assets["media/lilypadleap/background.webp"]" style="object-position: 70% 50%" />
            </picture>
        </div>

        <div class="fullscreen-footer">
            <div class="container">
                <picture>
                    <img decoding="async" class="titlecard" src="@Assets["media/lilypadleap/titlecard.svg"]" alt="Title card for the game 'Lilypad Leap'." />
                </picture>

                <div class="titlerow">
                    <div class="flexible-space"></div>
                    <SteamPlayButton href="/play/lilypadleap">Play in Browser</SteamPlayButton>
                </div>
            </div>
        </div>

        <div class="cascade-container">
            <div class="cascade" style="background: linear-gradient(to right, #5d708200 0%, #5d708230 75%, #5d708214 100%), url('media/noise.svg');">
            </div>
        </div>
    </div>

    <div class="container">
        <Block_ArticleHeader>
            <h1 data-nosnippet>Lilypad Leap</h1>
        </Block_ArticleHeader>

        <Block_ArticleIntroduction>
            <Sidebar>
                <img decoding="async" class="article-featuredimage" src="@Assets["media/lilypadleap/social.webp"]" alt="Promotional material for the game 'Lilypad Leap'." />

                <Block_PillCloud>
                    <Pill_OutOfTheBlueStudios />
                    <Pill_GameJam />
                    <Pill_Unity />
                    <Pill_CSharp />
                </Block_PillCloud>

                <p>@openGraphModel.Description.Default</p>

                <menu class="externallinks" aria-label="Project External links">
                </menu>

                <ShareLink Url="@openGraphModel.CanonicalUrl.Html" />
            </Sidebar>
            <Container>
            </Container>
        </Block_ArticleIntroduction>

        <Block_ArticleOutlined>
            <Sidebar>
                <aside>
                    <Block_TableOfContents />
                </aside>
            </Sidebar>
            <Content>

                <OutlineSection Id="work-in-progress" LinkName="Work-in-progress">
                    <Block_ArticleHeading>
                            <h2>Work-in-progress</h2>
                    </Block_ArticleHeading>

                    <Block_Callout Type="construction">
                        <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                        <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                    </Block_Callout>
                </OutlineSection>

            </Content>
        </Block_ArticleOutlined>
    </div>
</article>
