@layout DefaultLayout
@page "/portfolio/lostblues"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Lost Blues - Fydar",
        Description = "The clicker-style where you farm kelp and release fish.",
        CanonicalUrl = "https://fydar.dev/portfolio/lostblues",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/lostblues/social.webp",
                Alt = "Promotional material for the game 'Lost Blues'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Lost Blues",
                Item = "https://fydar.dev/portfolio/lostblues"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<section class="fullscreen" data-nosnippet>
    <div class="parallax-frame parallax-focalanchortop" style="--animation-time: 0.5;">
        <picture class="parallax-layer" style="--parallax-multiplier: 0.5">
            <img src="@Assets["media/lostblues/background.webp"]" style="image-rendering: pixelated;" />
        </picture>
    </div>

    <div class="fullscreen-footer">
        <div class="fullscreen-footer-container container container-wide">
            <picture>
                <img class="titlecard" src="@Assets["media/lostblues/titlecard.svg"]" alt="Title card for the game 'Lost Blues'." />
            </picture>

            <div class="titlerow">
                <div class="flexible-space"></div>
                <SteamPlayButton href="/play/lostblues">Play in Browser</SteamPlayButton>
            </div>
        </div>
    </div>
</section>

<div class="cascade-container">
    <div class="cascade" style="background: linear-gradient(to right, #0c6d5700 0%, #0c6d5730 75%, #0c6d5714 100%), url('media/noise.svg');">
    </div>
</div>

<section class="container container-wide" data-nosnippet>
    <h1>Lost Blues</h1>
</section>

<aside>
    <section>
        <img class="project-featuredimage" src="@Assets["media/lostblues/social.webp"]" alt="Promotional material for the game 'Lost Blues'." />

        <PillCloud>
            <Pill_GameJam />
            <Pill_Unity />
            <Pill_CSharp />
        </PillCloud>

        <p>@openGraphModel.Description.Default</p>

        <menu class="externallinks" aria-label="Project External links">
            <li><a href="https://youtu.be/N0eWZrliNG4" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-youtube" Alt="YouTube" /></a></li>
        </menu>

        <ShareLink Url="@openGraphModel.CanonicalUrl.Html" />
    </section>
</aside>

<section class="container">
    <EmbedYouTube Url="https://www.youtube-nocookie.com/embed/N0eWZrliNG4?si=h22aoTU4bFP9cmiF" />
</section>

<HeadingScope>
    <aside>
        <section style="position: sticky; top: 64px;">
            <div style="height: 5rem"></div>
            <TableOfContents />
        </section>

    </aside>

    <section class="container">

        <Heading Level="2" Identifier="gameboy-shader">
            <Prefix>Implementing the </Prefix>
            <Text>Procedural Kelp Swaying</Text>
            <Content>

                <Callout Type="construction">
                    <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                    <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                </Callout>

            </Content>
        </Heading>

    </section>
</HeadingScope>
