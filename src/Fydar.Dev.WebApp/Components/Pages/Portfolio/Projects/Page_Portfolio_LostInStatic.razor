@layout DefaultLayout
@page "/portfolio/lostinstatic"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Lost in Static - Fydar",
        Description = "Remote control a drone to take down a rouge AI controlling the station.",
        CanonicalUrl = "https://fydar.dev/portfolio/lostinstatic",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/lostinstatic/social.webp",
                Alt = "Promotional material for the game 'Lost in Static'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Lost in Static",
                Item = "https://fydar.dev/portfolio/lostinstatic"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<article class="page-lostinstatic">

    <div class="fullscreen" data-nosnippet>
        <div class="parallax-frame parallax-focalanchortop" style="--animation-time: 0.5;">
            <picture class="parallax-layer" style="--parallax-multiplier: 0.5">
                <img decoding="async" src="@Assets["media/lostinstatic/background.webp"]" />
            </picture>
        </div>

        <div class="fullscreen-footer">
            <div class="container">
                <picture>
                    <img decoding="async" class="titlecard" src="@Assets["media/lostinstatic/titlecard.svg"]" alt="Title card for the game 'Lost in Static'." />
                </picture>

                <div class="titlerow">
                    <div class="flexible-space"></div>
                    <SteamPlayButton href="/play/lostinstatic">Play in Browser</SteamPlayButton>
                </div>
            </div>
        </div>

        <div class="cascade-container">
            <div class="cascade" style="background: linear-gradient(to right, #9685aa00 0%, #9685aa30 75%, #9685aa14 100%), url('media/noise.svg');">
            </div>
        </div>
    </div>

    <div class="container">
        <Block_ArticleHeader>
            <h1 data-nosnippet>Lost in Static</h1>
        </Block_ArticleHeader>

        <Block_ArticleIntroduction>
            <Sidebar>
                <img decoding="async" class="article-featuredimage" src="@Assets["media/lostinstatic/social.webp"]" alt="Promotional material for the game 'Lost in Static'." />

                <Block_PillCloud>
                    <Pill_GameJam />
                    <Pill_Unity />
                    <Pill_CSharp />
                </Block_PillCloud>

                <p>@openGraphModel.Description.Default</p>

                <menu class="externallinks" aria-label="Project External links">
                    <li class="palette-youtube"><a href="https://youtu.be/Pms5NU5-IHQ" target="_blank"><SvgSprite Link="/icons.svg?v=1#icon-youtube" Alt="YouTube" /></a></li>
                </menu>

                <ShareLink Url="@openGraphModel.CanonicalUrl.Html" />
            </Sidebar>
            <Container>
                <EmbedYouTube Url="https://www.youtube-nocookie.com/embed/Pms5NU5-IHQ?si=Mrgnpsi5yvvkqaqR" />
            </Container>
        </Block_ArticleIntroduction>

        <Block_ArticleOutlined>
            <Sidebar>
                <aside>
                    <Block_TableOfContents />
                </aside>
            </Sidebar>
            <Content>

                <OutlineSection Id="cameras-and-hacking" LinkName="Cameras and Hacking">
                    <Block_ArticleHeading>
                        <hgroup>
                            <p>Implementing the</p>
                            <h2>Cameras and Hacking</h2>
                        </hgroup>
                    </Block_ArticleHeading>

                    <Block_Callout Type="construction">
                        <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                        <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                    </Block_Callout>
                </OutlineSection>

            </Content>
        </Block_ArticleOutlined>
    </div>
</article>
