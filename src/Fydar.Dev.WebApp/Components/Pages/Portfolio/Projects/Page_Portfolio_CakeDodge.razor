@layout DefaultLayout
@page "/portfolio/cakedodge"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Cake Dodge - Fydar",
        Description = "A mobile game created for a code test where the player must dodge falling cakes.",
        CanonicalUrl = "https://fydar.dev/portfolio/cakedodge",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/cakedodge/social.webp",
                Alt = "Promotional material for the game 'Cake Dodge'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Cake Dodge",
                Item = "https://fydar.dev/portfolio/cakedodge"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<section class="fullscreen" data-nosnippet>
    <div class="parallax-frame parallax-focalanchortop" style="--animation-time: 0.5;">
        <picture class="parallax-layer" style="--parallax-multiplier: 0.5">
            <img src="@Assets["media/cakedodge/background.webp"]" style="object-position: 42% 50%;" />
        </picture>
    </div>

    <div class="fullscreen-footer">
        <div class="fullscreen-footer-container container container-wide">
            <picture>
                <img class="titlecard" src="@Assets["media/cakedodge/titlecard.svg"]" alt="Title card for the game 'Cake Dodge'." />
            </picture>

            <div class="titlerow">
                <div class="flexible-space"></div>
                <SteamPlayButton href="/play/cakedodge">Play in Browser</SteamPlayButton>
            </div>
        </div>
    </div>
</section>

<div class="cascade-container">
    <div class="cascade" style="background: linear-gradient(to right, #302e3200 0%, #302e3230 75%, #302e3214 100%), url('media/noise.svg');">
    </div>
</div>

<section class="container container-wide" data-nosnippet>
    <h1>Cake Dodge</h1>
</section>

<aside class="project-summary">
    <section>
        <img class="project-featuredimage" src="@Assets["media/cakedodge/social.webp"]" alt="Promotional material for the game 'Cake Dodge'." />

        <PillCloud>
            <Pill_GameJam />
            <Pill_Unity />
            <Pill_CSharp />
            <Pill_TechnicalArt />
        </PillCloud>

        <p>@openGraphModel.Description.Default</p>

        <menu class="externallinks" aria-label="Project External links">
        </menu>

        <ShareLink Url="@openGraphModel.CanonicalUrl.Html" />

    </section>
</aside>

<HeadingScope>
    <aside>
        <section style="position: sticky; top: 64px;">
            <div style="height: 5rem"></div>
            <TableOfContents />
        </section>

    </aside>

    <section class="container">

        <Heading Level="2" Identifier="animated-character">
            <Prefix>Creating the</Prefix>
            <Text>Animated Character</Text>
            <Content>

                <figure class="figure-image">
                    <img loading="lazy" src="@Assets["media/cakedodge/cookie-walking.gif"]" />
                    <figcaption>The completed animated character walking left then right.</figcaption>
                </figure>

                <Callout Type="construction">
                    <Icon><SvgSprite Link="/icons.svg?v=1#fluent-emoji-high-contrast--construction" Alt="Check" /></Icon>
                    <ChildContent>This section of my website is currently <b>under construction</b>.</ChildContent>
                </Callout>

            </Content>
        </Heading>

    </section>
</HeadingScope>
