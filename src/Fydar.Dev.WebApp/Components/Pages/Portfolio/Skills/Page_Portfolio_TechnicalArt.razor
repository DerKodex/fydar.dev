@layout DefaultLayout
@page "/portfolio/technicalart"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Technical Art - Fydar",
        Description = "A collection of technical art pieces I've developed.",
        CanonicalUrl = "https://fydar.dev/portfolio/technicalart",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/header.webp",
                Alt = "A portrait of Fydar in an anime art style."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Technical Art",
                Item = "https://fydar.dev/portfolio/technicalart"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<article class="page-technicalart">
    <div class="container">
        <Block_ArticleHeader>
            <h1 data-nosnippet>Technical Art</h1>
        </Block_ArticleHeader>

        <Block_ArticleOutlined>
            <Sidebar>
                <aside>
                    <Block_TableOfContents />
                </aside>
            </Sidebar>
            <Content>
                <OutlineSection Id="professional" LinkName="Professional">
                    <Block_ArticleHeading>
                        <h2>Professional</h2>
                    </Block_ArticleHeading>

                    <Block_CoverGrid>

                        <CoverDate Date="2025">
                            <Cover_Phasmophobia />
                        </CoverDate>

                        <CoverDate Date="2024">
                            <Cover_UNO />
                        </CoverDate>

                        <CoverDate>
                            <Cover_Southfield />
                        </CoverDate>

                    </Block_CoverGrid>

                    <div style="height: 24px"></div>

                    <Block_CardGrid>
                        <Card>
                            <a class="card__link" href="https://www.gamesindustry.biz/technical-art-roles-what-they-are-and-how-to-get-one" target="_blank">EGX 2023 Panellist</a>
                            <picture>
                                <img class="card__image" decoding="async" loading="lazy" width="640" height="480" src="@Assets["media/companies/radicalforge/egx-card.webp"]" alt="Preview of the EGX talk." />
                            </picture>
                            <div class="container">
                                <header>
                                    <SvgSprite class="card-keyicon" Link="/icons.svg?v=1#tabler--brush" />
                                    <h3>EGX 2023 Panellist</h3>
                                </header>
                                <p>Technical art roles: What they are, and how to get one</p>
                            </div>
                        </Card>
                    </Block_CardGrid>
                </OutlineSection>
            </Content>
        </Block_ArticleOutlined>
    </div>
</article>
