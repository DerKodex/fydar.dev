@layout DefaultLayout
@page "/portfolio/backend"
@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Backend Engineering - Fydar",
        Description = "A collection of backend I've developed.",
        CanonicalUrl = "https://fydar.dev/portfolio/backend",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/header.webp",
                Alt = "A portrait of Fydar in an anime art style."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Portfolio",
                Item = "https://fydar.dev/portfolio"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Backend Engineering",
                Item = "https://fydar.dev/portfolio/backend"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
</HeadContent>

<article class="page-backend">
    <div class="container">
        <Block_ArticleHeader>
            <h1 data-nosnippet>Backend Engineering</h1>
        </Block_ArticleHeader>

        <Block_ArticleOutlined>
            <Sidebar>
                <aside>
                    <Block_TableOfContents />
                </aside>
            </Sidebar>
            <Content>
                <OutlineSection Id="professional" LinkName="Professional">
                    <Block_ArticleHeading>
                        <h2>Professional</h2>
                    </Block_ArticleHeading>

                    <Block_CoverGrid>

                        <CoverDate Date="2022">
                            <Cover_StarCitizen />
                        </CoverDate>

                        <CoverDate>
                            <Cover_Squadron42 />
                        </CoverDate>

                        <CoverDate Date="2020">
                            <Cover_LegoStarWarsBattles />
                        </CoverDate>

                    </Block_CoverGrid>
                </OutlineSection>

                <OutlineSection Id="documentation" LinkName="Hobbyist" class="palette-backend">
                    <Block_ArticleHeading>
                        <h2>Hobbyist</h2>
                    </Block_ArticleHeading>

                    <Block_CardGrid>
                        <Card>
                            <a class="card__link" href="/portfolio/mywebsite">My Website</a>
                            <div class="container">
                                <header>
                                    <SvgSprite class="card-keyicon" Link="/icons.svg?v=1#icon-fydar" />
                                    <h3>My Website</h3>
                                </header>
                                <Block_PillCloud>
                                    <Pill_AspNetCore />
                                </Block_PillCloud>
                                <p>This portfolio website made using <b>ASP.NET Core</b> and hosted in <b>AWS</b>.</p>
                            </div>
                        </Card>
                        <Card>
                            <a class="card__link" href="/portfolio/pewpew">Pew Pew</a>
                            <div class="container">
                                <header>
                                    <SvgSprite class="card-keyicon" Link="/icons.svg?v=1#icon-network-right-solid" />
                                    <h3>Pew Pew</h3>
                                </header>
                                <Block_PillCloud>
                                    <Pill_AspNetCore />
                                </Block_PillCloud>
                                <p>A 20v20 .io style browser game made in 48 hours using <b>ASP.NET Core</b> and hosted in <b>AWS</b>.</p>
                            </div>
                        </Card>
                    </Block_CardGrid>
                </OutlineSection>
            </Content>
        </Block_ArticleOutlined>
    </div>
</article>
