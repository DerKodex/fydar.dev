@layout DefaultLayout
@page "/portfolio/systems"
@{
	var openGraphModel = new OpenGraphModel()
	{
		Title = "Systems Programming - Fydar",
		Description = "A collection of systems I've developed.",
		CanonicalUrl = "https://fydar.dev/portfolio/systems",
		Properties = [
			new OpenGraphModelImage()
			{
				Url = "https://fydar.dev/media/header.webp",
				Alt = "A portrait of Fydar in an anime art style."
			}
		]
	};
	var linkData = new LinkData()
	{
		new LinkDataBreadcrumbList()
		{
			new LinkDataBreadcrumbListItem()
			{
				Name = "Portfolio",
				Item = "https://fydar.dev/portfolio"
			},
			new LinkDataBreadcrumbListItem()
			{
				Name = "Systems Programming",
				Item = "https://fydar.dev/portfolio/systems"
			}
		}
	};
}

<HeadContent>
	<OpenGraphComponent Model="@openGraphModel" />
	<LinkDataComponent Model="@linkData" />
</HeadContent>

<article class="page-systems">
    <div class="container">
        <Block_ArticleHeader>
            <h1 data-nosnippet>Systems Engineering</h1>
        </Block_ArticleHeader>

        <Block_ArticleOutlined>
            <Sidebar>
                <aside>
                    <Block_TableOfContents />
                </aside>
            </Sidebar>
            <Content>
                <OutlineSection Id="professional" LinkName="Professional">
                    <Block_ArticleHeading>
                        <h2>Professional</h2>
                    </Block_ArticleHeading>

                    <p>I have always enjoyed tackling game systems, right from the start of my career with my love for RPG games.</p>

                    <Block_CoverGrid>

                        <CoverDate Date="2022">
                            <Cover_StarCitizen />
                        </CoverDate>

                        <CoverDate>
                            <Cover_Squadron42 />
                        </CoverDate>

                        <CoverDate Date="2018">
                            <Cover_Eitr />
                        </CoverDate>

                    </Block_CoverGrid>
                </OutlineSection>

                <OutlineSection Id="documentation" LinkName="Hobbyist">
                    <Block_ArticleHeading>
                        <h2>Hobbyist</h2>
                    </Block_ArticleHeading>

                    <Block_CardGrid>
                        <Card>
                            <a class="card__link" href="/portfolio/behaviour">Behaviour</a>
                            <SvgSprite class="card__image" Link="/icons.svg?v=1#icon-nodeeditor" Alt="An illustration of the node based editor." />
                            <div class="container">
                                <header>
                                    <SvgSprite class="card-keyicon" Link="/icons.svg?v=1#icon-fydarbehaviour" />
                                    <h3>Behaviour</h3>
                                </header>
                                <p><b>Data-driven</b> and <b>flexible</b> <b>node-based</b> behaviour engine for items, abilities, quests, enemies, achievements, and more.</p>
                            </div>
                        </Card>
                        <Card>
                            <a class="card__link" href="/portfolio/inventory">Inventory</a>
                            <SvgSprite class="card__image" Link="/icons.svg?v=1#icon-inventory" Alt="An illustration of the node based editor." />
                            <div class="container">
                                <header>
                                    <SvgSprite class="card-keyicon" Link="/icons.svg?v=1#icon-fydarinventory" />
                                    <h3>Inventory</h3>
                                </header>
                                <p>Complete item and inventory system with transactions, constraints, equipment, tooltips, and more.</p>
                            </div>
                        </Card>
                        <Card>
                            <a class="card__link" href="/portfolio/entities">Entities</a>
                            <div class="container">
                                <header>
                                    <SvgSprite class="card-keyicon" Link="/icons.svg?v=1#icon-fydarentities" />
                                    <h3>Entities</h3>
                                </header>
                                <p>Highly-optimized ECS with a native and intuitive C# API.</p>
                            </div>
                        </Card>
                        <Card>
                            <a class="card__link" href="/portfolio/numerics">Numerics</a>
                            <div class="container">
                                <header>
                                    <SvgSprite class="card-keyicon" Link="/icons.svg?v=1#icon-numbers" />
                                    <h3>Numerics</h3>
                                </header>
                                <p>Deterministic mathematics library built around a custom Fixed-point numeric type.</p>
                            </div>
                        </Card>
                        <Card>
                            <a class="card__link" href="/portfolio/geometry">Geometry</a>
                            <div class="container">
                                <header>
                                    <SvgSprite class="card-keyicon" Link="/icons.svg?v=1#icon-fydargeometry" />
                                    <h3>Geometry</h3>
                                </header>
                                <p>Deterministic 2D and 3D geometry library utilising Fixed-point numerics.</p>
                            </div>
                        </Card>
                        <Card>
                            <a class="card__link" href="/portfolio/lodestone">Lodestone</a>
                            <div class="container">
                                <header>
                                    <SvgSprite class="card-keyicon" Link="/icons.svg?v=1#icon-network-right-solid" />
                                    <h3>Lodestone</h3>
                                </header>
                                <p>An asset build pipeline, asset database, and build system.</p>
                            </div>
                        </Card>
                    </Block_CardGrid>
                </OutlineSection>
            </Content>
        </Block_ArticleOutlined>
    </div>
</article>
