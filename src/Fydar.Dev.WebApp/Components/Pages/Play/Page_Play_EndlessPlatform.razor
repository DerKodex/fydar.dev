@layout GameLayout
@page "/play/endlessplatform"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Endless Platform - Fydar",
        Description = "A fully procedurally generated spline-based terrain for a 2D platformer.",
        CanonicalUrl = "https://fydar.dev/play/endlessplatform",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/endlessplatform/social.webp",
                Alt = "Promotional material for the game 'Endless Platform'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Endless Platform",
                Item = "https://fydar.dev/play/endlessplatform"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/endlessplatform/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/endlessplatform/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/endlessplatform/build/endlessplatform.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Endless Platform",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/endlessplatform/build/endlessplatform.loader.js"],
        FrameworkUrl = Assets["/play/endlessplatform/build/endlessplatform.framework.js.br"],
        CodeUrl = Assets["/play/endlessplatform/build/endlessplatform.wasm.br"],
        DataUrl = Assets["/play/endlessplatform/build/endlessplatform.data.br"],
        StreamingAssetsUrl = "/play/endlessplatform/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/endlessplatform/favicon.ico"]" alt="The logo for 'Endless Platform'." class="embed--placeholdermainappicon" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/endlessplatform/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
