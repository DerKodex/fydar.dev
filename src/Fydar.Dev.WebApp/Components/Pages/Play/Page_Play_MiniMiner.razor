@layout GameLayout
@page "/play/miniminer"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Mini Miner - Fydar",
        Description = "The Game Boy demake of the Nintendo DS Pokémon Diamond and Pearl underground mining minigame.",
        CanonicalUrl = "https://fydar.dev/play/miniminer",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/miniminer/social.webp",
                Alt = "Promotional material for the game 'Mini Miner'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Mini Miner",
                Item = "https://fydar.dev/play/miniminer"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/miniminer/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/miniminer/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/miniminer/build/miniminer.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Mini Miner",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/miniminer/build/miniminer.loader.js"],
        FrameworkUrl = Assets["/play/miniminer/build/miniminer.framework.js.br"],
        CodeUrl = Assets["/play/miniminer/build/miniminer.wasm.br"],
        DataUrl = Assets["/play/miniminer/build/miniminer.data.br"],
        StreamingAssetsUrl = "/play/miniminer/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/miniminer/favicon.ico"]" alt="The logo for 'Mini Miner'." style="width: 200px; max-width: 90%; margin-bottom: 32px;" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/miniminer/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
