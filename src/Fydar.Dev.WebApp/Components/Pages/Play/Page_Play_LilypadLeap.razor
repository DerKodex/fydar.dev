@layout GameLayout
@page "/play/lilypadleap"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Lilypad Leap - Fydar",
        Description = "A relaxing arcade game.",
        CanonicalUrl = "https://fydar.dev/play/lilypadleap",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/lilypadleap/social.webp",
                Alt = "Promotional material for the game 'Lilypad Leap'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Lilypad Leap",
                Item = "https://fydar.dev/play/lilypadleap"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/lilypadleap/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/lilypadleap/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/lilypadleap/build/lilypadleap.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Lilypad Leap",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Out of the Blue Studios",
        LoaderUrl = Assets["/play/lilypadleap/build/lilypadleap.loader.js"],
        FrameworkUrl = Assets["/play/lilypadleap/build/lilypadleap.framework.js.br"],
        CodeUrl = Assets["/play/lilypadleap/build/lilypadleap.wasm.br"],
        DataUrl = Assets["/play/lilypadleap/build/lilypadleap.data.br"],
        StreamingAssetsUrl = "/play/lilypadleap/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/lilypadleap/favicon.ico"]" alt="The logo for 'Lilypad Leap'." style="width: 200px; max-width: 90%; margin-bottom: 32px;" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/lilypadleap/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
