@layout GameLayout
@page "/play/bloodlust"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Bloodlust - Fydar",
        Description = "The morality of a recently turned vampire comes into question when his thirst for life must be quenched.",
        CanonicalUrl = "https://fydar.dev/play/bloodlust",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/bloodlust/social.webp",
                Alt = "Promotional material for the game 'Bloodlust'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Bloodlust",
                Item = "https://fydar.dev/play/bloodlust"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#2c3840">
    <link rel="shortcut icon" href="@Assets["/play/bloodlust/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/bloodlust/manifest.webmanifest"]">
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Bloodlust",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/bloodlust/build/bloodlust.loader.js"],
        FrameworkUrl = Assets["/play/bloodlust/build/bloodlust.framework.js.br"],
        CodeUrl = Assets["/play/bloodlust/build/bloodlust.wasm.br"],
        DataUrl = Assets["/play/bloodlust/build/bloodlust.data.br"],
        StreamingAssetsUrl = "/play/bloodlust/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/bloodlust/favicon.ico"]" alt="The logo for 'Bloodlust'." style="width: 200px; max-width: 90%; margin-bottom: 32px;" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/bloodlust/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
