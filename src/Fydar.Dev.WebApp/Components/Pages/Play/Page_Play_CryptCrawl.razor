@layout GameLayout
@page "/play/cryptcrawl"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Crypt Crawl - Fydar",
        Description = "A pixel art dungeon crawler with dungeon textures generated in Substance Designer.",
        CanonicalUrl = "https://fydar.dev/play/cryptcrawl",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/cryptcrawl/social.webp",
                Alt = "Promotional material for the game 'Crypt Crawl'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Crypt Crawl",
                Item = "https://fydar.dev/play/cryptcrawl"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/cryptcrawl/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/cryptcrawl/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/cryptcrawl/build/cryptcrawl.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Crypt Crawl",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/cryptcrawl/build/cryptcrawl.loader.js"],
        FrameworkUrl = Assets["/play/cryptcrawl/build/cryptcrawl.framework.js.br"],
        CodeUrl = Assets["/play/cryptcrawl/build/cryptcrawl.wasm.br"],
        DataUrl = Assets["/play/cryptcrawl/build/cryptcrawl.data.br"],
        StreamingAssetsUrl = "/play/cryptcrawl/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/cryptcrawl/favicon.ico"]" alt="The logo for 'Crypt Crawl'." class="embed--placeholdermainappicon" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/cryptcrawl/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
