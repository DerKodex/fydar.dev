@layout GameLayout
@page "/play/raidhealersimulator"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Raid Healer Simulator - Fydar",
        Description = "The simulation experience of what it’s like to be a healer in an MMORPG raid, complete with a variety of abilities and a challenging boss battle.",
        CanonicalUrl = "https://fydar.dev/play/raidhealersimulator",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/raidhealersimulator/social.webp",
                Alt = "Promotional material for the game 'Raid Healer Simulator'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Raid Healer Simulator",
                Item = "https://fydar.dev/play/raidhealersimulator"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/raidhealersimulator/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/raidhealersimulator/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/raidhealersimulator/build/raidhealersimulator.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Raid Healer Simulator",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/raidhealersimulator/build/raidhealersimulator.loader.js"],
        FrameworkUrl = Assets["/play/raidhealersimulator/build/raidhealersimulator.framework.js.br"],
        CodeUrl = Assets["/play/raidhealersimulator/build/raidhealersimulator.wasm.br"],
        DataUrl = Assets["/play/raidhealersimulator/build/raidhealersimulator.data.br"],
        StreamingAssetsUrl = "/play/raidhealersimulator/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/raidhealersimulator/favicon.ico"]" alt="The logo for 'Raid Healer Simulator'." style="width: 200px; max-width: 90%; margin-bottom: 32px;" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/raidhealersimulator/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
