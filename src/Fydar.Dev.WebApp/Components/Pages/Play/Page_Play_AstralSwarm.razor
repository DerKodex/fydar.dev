@layout GameLayout
@page "/play/astralswarm"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Astral Swarm - Fydar",
        Description = "A space shooter.",
        CanonicalUrl = "https://fydar.dev/play/astralswarm",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/astralswarm/social.webp",
                Alt = "Promotional material for the game 'Astral Swarm'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Astral Swarm",
                Item = "https://fydar.dev/play/astralswarm"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/astralswarm/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/astralswarm/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/astralswarm/build/astralswarm.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Astral Swarm",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Out of the Blue Studios",
        LoaderUrl = Assets["/play/astralswarm/build/astralswarm.loader.js"],
        FrameworkUrl = Assets["/play/astralswarm/build/astralswarm.framework.js.br"],
        CodeUrl = Assets["/play/astralswarm/build/astralswarm.wasm.br"],
        DataUrl = Assets["/play/astralswarm/build/astralswarm.data.br"],
        StreamingAssetsUrl = "/play/astralswarm/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/astralswarm/favicon.ico"]" alt="The logo for 'Astral Swarm'." style="width: 200px; max-width: 90%; margin-bottom: 32px;" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/astralswarm/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
