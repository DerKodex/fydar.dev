@layout GameLayout
@page "/play/astralelites"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Astral Elites - Fydar",
        Description = "The physics-based and fast-paced asteroids clone for the modern era.",
        CanonicalUrl = "https://fydar.dev/play/astralelites",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/astralelites/social.webp",
                Alt = "Promotional material for the game 'Astral Elites'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Astral Elites",
                Item = "https://fydar.dev/play/astralelites"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/astralelites/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/astralelites/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/astralelites/build/astralelites.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Astral Elites",
        ProductVersion = new Version(0, 1, 1, 1),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/astralelites/build/astralelites.loader.js"],
        FrameworkUrl = Assets["/play/astralelites/build/astralelites.framework.js.br"],
        CodeUrl = Assets["/play/astralelites/build/astralelites.wasm.br"],
        DataUrl = Assets["/play/astralelites/build/astralelites.data.br"],
        StreamingAssetsUrl = "/play/astralelites/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Interactive>
        <svg viewBox="0 0 1777 1000" style="position: absolute; top: 0; left: 0; height: 100%;">
            <style>
                @@keyframes twinkle {
                    0% {
                        opacity: 0;
                    }

                    16.3% {
                        opacity: 1;
                    }

                    31.2% {
                        opacity: 1;
                    }

                    50% {
                        opacity: 0;
                    }

                    100% {
                        opacity: 0;
                    }
                }

                .star {
                    fill: white;
                    opacity: 0;
                    animation: twinkle 4s infinite;
                }

                .small {
                    width: 3px;
                    height: 3px;
                }

                .medium { 
                    width: 4px;
                    height: 4px;
                }

                .large {
                    width: 5px;
                    height: 5px;
                }
            </style>

            <rect x="55" y="500" class="star medium" style="animation-delay: -2.78s;" />
            <rect x="111" y="111" class="star large" style="animation-delay: -1.54s;" />
            <rect x="111" y="55" class="star small" style="animation-delay: -0.12s;" />
            <rect x="166" y="944" class="star small" style="animation-delay: -1.41s;" />
            <rect x="1666" y="166" class="star medium" style="animation-delay: -2.14s;" />
            <rect x="1755" y="466" class="star small" style="animation-delay: -3.33s;" />
            <rect x="222" y="333" class="star small" style="animation-delay: -2.29s;" />
            <rect x="277" y="222" class="star small" style="animation-delay: -3.91s;" />
            <rect x="333" y="722" class="star small" style="animation-delay: -3.72s;" />
            <rect x="355" y="577" class="star small" style="animation-delay: -1.02s;" />
            <rect x="444" y="133" class="star medium" style="animation-delay: -3.45s;" />
            <rect x="444" y="888" class="star medium" style="animation-delay: -2.11s;" />
            <rect x="500" y="388" class="star large" style="animation-delay: -0.98s;" />
            <rect x="555" y="555" class="star large" style="animation-delay: -2.65s;" />
            <rect x="611" y="800" class="star medium" style="animation-delay: -3.05s;" />
            <rect x="666" y="222" class="star small" style="animation-delay: -0.81s;" />
            <rect x="755" y="422" class="star large" style="animation-delay: -3.12s;" />
            <rect x="777" y="33" class="star large" style="animation-delay: -1.89s;" />
            <rect x="888" y="444" class="star medium" style="animation-delay: -0.36s;" />
            <rect x="888" y="888" class="star large" style="animation-delay: -0.22s;" />
            <rect x="944" y="200" class="star large" style="animation-delay: -1.23s;" />
            <rect x="1000" y="666" class="star large" style="animation-delay: -0.63s;" />
            <rect x="1000" y="1000" class="star large" style="animation-delay: -0.07s;" />
            <rect x="1044" y="511" class="star small" style="animation-delay: -0.44s;" />
            <rect x="1111" y="111" class="star small" style="animation-delay: -3.58s;" />
            <rect x="1222" y="333" class="star medium" style="animation-delay: -2.56s;" />
            <rect x="1277" y="977" class="star small" style="animation-delay: -2.87s;" />
            <rect x="1333" y="777" class="star medium" style="animation-delay: -3.82s;" />
            <rect x="1333" y="88" class="star small" style="animation-delay: -0.76s;" />
            <rect x="1388" y="555" class="star medium" style="animation-delay: -1.67s;" />
            <rect x="1500" y="44" class="star medium" style="animation-delay: -0.55s;" />
            <rect x="1555" y="555" class="star small" style="animation-delay: -1.94s;" />
            <rect x="1555" y="833" class="star medium" style="animation-delay: -1.15s;" />
            <rect x="214" y="842" class="star medium" style="animation-delay: -1.23s;" />
            <rect x="1582" y="115" class="star large" style="animation-delay: -3.45s;" />
            <rect x="45" y="478" class="star small" style="animation-delay: -0.12s;" />
            <rect x="1233" y="912" class="star small" style="animation-delay: -2.87s;" />
            <rect x="1610" y="550" class="star medium" style="animation-delay: -1.14s;" />
            <rect x="456" y="89" class="star small" style="animation-delay: -3.98s;" />
            <rect x="789" y="333" class="star large" style="animation-delay: -0.56s;" />
            <rect x="122" y="745" class="star medium" style="animation-delay: -2.21s;" />
            <rect x="1405" y="678" class="star small" style="animation-delay: -1.76s;" />
            <rect x="912" y="44" class="star large" style="animation-delay: -3.02s;" />
            <rect x="1156" y="223" class="star small" style="animation-delay: -2.41s;" />
            <rect x="1712" y="890" class="star large" style="animation-delay: -1.65s;" />
            <rect x="634" y="412" class="star small" style="animation-delay: -3.29s;" />
            <rect x="511" y="955" class="star medium" style="animation-delay: -0.45s;" />
            <rect x="1378" y="189" class="star large" style="animation-delay: -2.76s;" />
            <rect x="98" y="22" class="star medium" style="animation-delay: -3.11s;" />
            <rect x="845" y="612" class="star small" style="animation-delay: -1.34s;" />
            <rect x="1655" y="345" class="star large" style="animation-delay: -0.92s;" />
            <rect x="278" y="278" class="star small" style="animation-delay: -3.54s;" />
            <rect x="1023" y="734" class="star medium" style="animation-delay: -2.18s;" />
            <rect x="489" y="689" class="star large" style="animation-delay: -0.07s;" />
            <rect x="1512" y="978" class="star small" style="animation-delay: -1.55s;" />
            <rect x="723" y="823" class="star medium" style="animation-delay: -3.67s;" />
        </svg>

        <script>
            const embedContainer = document.querySelector('#@context');
            const stars = document.querySelectorAll('.star');
            const svgWidth = 1777;
            const svgHeight = 1000;

            stars.forEach(star => {
                star.addEventListener('animationiteration', () => {
                    if (!embedContainer.classList.contains('loading')) {
                        star.style.animationIterationCount = '1';
                    }
                    else
                    {
                        const newX = Math.floor(Math.random() * svgWidth);
                        const newY = Math.floor(Math.random() * svgHeight);
                        star.setAttribute('x', newX);
                        star.setAttribute('y', newY);
                    }
                });
            });
        </script>

        <style>
            #@context div.embed--placeholder {
                background: none;
            }

            #@context div.embed--interactive {
                background: none;
                transition: background 0.05s linear;
            }

            #@(context).loading div.embed--interactive {
                background: #161618;
            }
        </style>

    </Interactive>

    <Placeholder>
        <img decoding="async" src="@Assets["play/astralelites/favicon.ico"]" alt="The logo for 'Astral Elites'." class="embed--placeholdermainappicon" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/astralelites/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
