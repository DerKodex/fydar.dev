@layout GameLayout
@page "/play/sofarfromhome"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play So Far From Home - Fydar",
        Description = "A dungeon crawler with a powerful node-based editor for the RPG system.",
        CanonicalUrl = "https://fydar.dev/play/sofarfromhome",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/sofarfromhome/social.webp",
                Alt = "Promotional material for the game 'So Far From Home'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "So Far From Home",
                Item = "https://fydar.dev/play/sofarfromhome"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/sofarfromhome/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/sofarfromhome/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/sofarfromhome/build/sofarfromhome.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Lost in Static",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/sofarfromhome/build/sofarfromhome.loader.js"],
        FrameworkUrl = Assets["/play/sofarfromhome/build/sofarfromhome.framework.js.br"],
        CodeUrl = Assets["/play/sofarfromhome/build/sofarfromhome.wasm.br"],
        DataUrl = Assets["/play/sofarfromhome/build/sofarfromhome.data.br"],
        StreamingAssetsUrl = "/play/sofarfromhome/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/sofarfromhome/favicon.ico"]" alt="The logo for 'So Far From Home'." style="width: 200px; max-width: 90%; margin-bottom: 32px;" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/sofarfromhome/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
