@layout GameLayout
@page "/play/snoot"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Snoot - Fydar",
        Description = "Restore life to a desolate world by exploring a sandbox of crafting recipes. On your adventure you will bring rain, grass, bugs, birds, and bees.",
        CanonicalUrl = "https://fydar.dev/play/snoot",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/snoot/social.webp",
                Alt = "Promotional material for the game 'Snoot'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Snoot",
                Item = "https://fydar.dev/play/snoot"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/snoot/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/snoot/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/snoot/build/snoot.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Snoot",
        ProductVersion = new Version(0, 0, 4),
        CompanyName = "Fydar, Emma, and Tim",
        LoaderUrl = Assets["/play/snoot/build/snoot.loader.js"],
        FrameworkUrl = Assets["/play/snoot/build/snoot.framework.js.br"],
        CodeUrl = Assets["/play/snoot/build/snoot.wasm.br"],
        DataUrl = Assets["/play/snoot/build/snoot.data.br"],
        StreamingAssetsUrl = "/play/snoot/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/snoot/favicon.ico"]" alt="The logo for 'Snoot'." style="width: 200px; max-width: 90%; margin-bottom: 32px;" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/snoot/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
