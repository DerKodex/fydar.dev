@layout GameLayout
@page "/play/thenewearthconflict"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play The New Earth Conflict - Fydar",
        Description = "A realtime space strategy game where the player takes the pilot seat of a battleship.",
        CanonicalUrl = "https://fydar.dev/play/thenewearthconflict",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/thenewearthconflict/social.webp",
                Alt = "Promotional material for the game 'The New Earth Conflict'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "The New Earth Conflict",
                Item = "https://fydar.dev/play/thenewearthconflict"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/thenewearthconflict/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/thenewearthconflict/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/thenewearthconflict/build/thenewearthconflict.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "The New Earth Conflict",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/thenewearthconflict/build/thenewearthconflict.loader.js"],
        FrameworkUrl = Assets["/play/thenewearthconflict/build/thenewearthconflict.framework.js.br"],
        CodeUrl = Assets["/play/thenewearthconflict/build/thenewearthconflict.wasm.br"],
        DataUrl = Assets["/play/thenewearthconflict/build/thenewearthconflict.data.br"],
        StreamingAssetsUrl = "/play/thenewearthconflict/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/thenewearthconflict/favicon.ico"]" alt="The logo for 'The New Earth Conflict'." style="width: 200px; max-width: 90%; margin-bottom: 32px;" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/thenewearthconflict/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
