@layout GameLayout
@page "/play/cakedodge"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Cake Dodge - Fydar",
        Description = "Play as Cookie, a little monster who is unfortunately allergic to cake.",
        CanonicalUrl = "https://fydar.dev/play/cakedodge",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/cakedodge/social.webp",
                Alt = "Promotional material for the game 'Cake Dodge'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Cake Dodge",
                Item = "https://fydar.dev/play/cakedodge"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/cakedodge/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/cakedodge/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/cakedodge/build/cakedodge.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Cake Dodge",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/cakedodge/build/cakedodge.loader.js"],
        FrameworkUrl = Assets["/play/cakedodge/build/cakedodge.framework.js.br"],
        CodeUrl = Assets["/play/cakedodge/build/cakedodge.wasm.br"],
        DataUrl = Assets["/play/cakedodge/build/cakedodge.data.br"],
        StreamingAssetsUrl = "/play/cakedodge/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/cakedodge/loading.svg"]" alt="The logo for 'Cake Dodge'." class="embed--placeholdermainappicon" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/cakedodge/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
