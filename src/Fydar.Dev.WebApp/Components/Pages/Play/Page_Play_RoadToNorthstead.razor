@layout GameLayout
@page "/play/roadtonorthstead"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Road to Northstead - Fydar",
        Description = "The game jam visual novel with questing and crafting to survive the night.",
        CanonicalUrl = "https://fydar.dev/portfolio/roadtonorthstead",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/roadtonorthstead/social.webp",
                Alt = "Promotional material for the game 'Road to Northstead'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Road to Northstead",
                Item = "https://fydar.dev/play/roadtonorthstead"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/roadtonorthstead/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/roadtonorthstead/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/roadtonorthstead/build/roadtonorthstead.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Road to Northstead",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/roadtonorthstead/build/roadtonorthstead.loader.js"],
        FrameworkUrl = Assets["/play/roadtonorthstead/build/roadtonorthstead.framework.js.br"],
        CodeUrl = Assets["/play/roadtonorthstead/build/roadtonorthstead.wasm.br"],
        DataUrl = Assets["/play/roadtonorthstead/build/roadtonorthstead.data.br"],
        StreamingAssetsUrl = "/play/roadtonorthstead/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/roadtonorthstead/favicon.ico"]" alt="The logo for 'Road to Northstead'." class="embed--placeholdermainappicon" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/roadtonorthstead/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
