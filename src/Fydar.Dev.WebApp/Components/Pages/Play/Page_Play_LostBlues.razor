@layout GameLayout
@page "/play/lostblues"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play Lost Blues - Fydar",
        Description = "The clicker-style where you farm kelp and release fish.",
        CanonicalUrl = "https://fydar.dev/play/lostblues",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/lostblues/social.webp",
                Alt = "Promotional material for the game 'Lost Blues'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "Lost Blues",
                Item = "https://fydar.dev/play/lostblues"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/lostblues/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/lostblues/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/lostblues/build/lostblues.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "Lost Blues",
        ProductVersion = new Version(0, 1, 1),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/lostblues/build/lostblues.loader.js"],
        FrameworkUrl = Assets["/play/lostblues/build/lostblues.framework.js.br"],
        CodeUrl = Assets["/play/lostblues/build/lostblues.wasm.br"],
        DataUrl = Assets["/play/lostblues/build/lostblues.data.br"],
        StreamingAssetsUrl = "/play/lostblues/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/lostblues/favicon.ico"]" alt="The logo for 'Lost Blues'." style="width: 200px; max-width: 90%; margin-bottom: 32px;" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/lostblues/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
