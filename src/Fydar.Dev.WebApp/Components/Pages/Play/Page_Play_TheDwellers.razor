@layout GameLayout
@page "/play/thedwellers"

@inject Noncer noncer;

@{
    var openGraphModel = new OpenGraphModel()
    {
        Title = "Play The Dwellers - Fydar",
        Description = "A dungeon crawler with a powerful node-based editor for the RPG system.",
        CanonicalUrl = "https://fydar.dev/play/thedwellers",
        Properties = [
            new OpenGraphModelImage()
            {
                Url = "https://fydar.dev/media/thedwellers/social.webp",
                Alt = "Promotional material for the game 'The Dwellers'."
            }
        ]
    };
    var linkData = new LinkData()
    {
        new LinkDataBreadcrumbList()
        {
            new LinkDataBreadcrumbListItem()
            {
                Name = "Play",
                Item = "https://fydar.dev/play/"
            },
            new LinkDataBreadcrumbListItem()
            {
                Name = "The Dwellers",
                Item = "https://fydar.dev/play/thedwellers"
            }
        }
    };
}

<HeadContent>
    <OpenGraphComponent Model="@openGraphModel" />
    <LinkDataComponent Model="@linkData" />
    <meta name="theme-color" content="#161618">
    <link rel="shortcut icon" href="@Assets["/play/thedwellers/favicon.ico"]">
    <link rel="manifest" href="@Assets["/play/thedwellers/manifest.webmanifest"]">
    <link rel="preload" href="@Assets["/play/thedwellers/build/thedwellers.loader.js"]" as="script" fetchpriority="high" />
</HeadContent>

@{
    var embedUnityConfig = new EmbedUnityConfig()
    {
        ProductName = "The Dwellers",
        ProductVersion = new Version(0, 1, 0),
        CompanyName = "Fydar",
        LoaderUrl = Assets["/play/thedwellers/build/thedwellers.loader.js"],
        FrameworkUrl = Assets["/play/thedwellers/build/thedwellers.framework.js.br"],
        CodeUrl = Assets["/play/thedwellers/build/thedwellers.wasm.br"],
        DataUrl = Assets["/play/thedwellers/build/thedwellers.data.br"],
        StreamingAssetsUrl = "/play/thedwellers/StreamingAssets",
        Arguments = [],
    };
}

<EmbedUnity Config="embedUnityConfig">
    <Placeholder>
        <img decoding="async" src="@Assets["play/thedwellers/favicon.ico"]" alt="The logo for 'The Dwellers'." class="embed--placeholdermainappicon" />
    </Placeholder>
</EmbedUnity>

<script nonce="@noncer.Nonce">
    var serviceWorkerUrl = "@Assets["play/thedwellers/ServiceWorker.js"]";
    window.addEventListener("load", function () {
        if ("serviceWorker" in navigator) {
            navigator.serviceWorker.register(serviceWorkerUrl);
        }
    });
</script>
